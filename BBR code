<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>B. Braun - Форма связи</title>
  <meta
    name="description"
    content="Оставьте контактные данные, чтобы представители B. Braun могли с вами связаться."
  />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap"
    rel="stylesheet"
  />

  <script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>

  <style>
    :root {
      --bb-green-50: #f7fcf3;
      --bb-green-100: #ebf6e0;
      --bb-green-200: #d9edc6;
      --bb-green-300: #c4e2a6;
      --bb-green-400: #a6d27a;
      --bb-green-500: #88bc53;
      --bb-green-600: #699d3c;
      --bb-green-700: #507b2d;
      --bb-green-800: #35531e;
      --ink: #22331f;
      --muted: #67775f;
      --white: #ffffff;
      --shadow: 0 24px 70px rgba(93, 132, 52, 0.18);
      --radius-xl: 28px;
      --radius-lg: 20px;
    }

    * {
      box-sizing: border-box;
    }

    html,
    body {
      margin: 0;
      padding: 0;
      min-height: 100%;
      font-family: "Manrope", sans-serif;
      color: var(--ink);
      background:
        radial-gradient(circle at top left, rgba(196, 226, 166, 0.72), transparent 32%),
        radial-gradient(circle at 90% 20%, rgba(136, 188, 83, 0.16), transparent 24%),
        linear-gradient(180deg, #fbfff8 0%, #eef7e6 100%);
    }

    body {
      overflow-x: hidden;
    }

    .page {
      min-height: 100vh;
      display: grid;
      place-items: center;
      padding: 28px 16px;
    }

    .card {
      width: min(980px, 100%);
      background: rgba(255, 255, 255, 0.9);
      border: 1px solid rgba(105, 157, 60, 0.14);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow);
      backdrop-filter: blur(10px);
      overflow: hidden;
    }

    .hero {
      padding: 30px 30px 12px;
    }

    .logo-row {
      display: inline-flex;
      align-items: center;
      gap: 14px;
      margin-bottom: 18px;
      padding: 10px 14px;
      border-radius: 999px;
      background: linear-gradient(180deg, #f8fff3 0%, #eef8e3 100%);
      border: 1px solid rgba(136, 188, 83, 0.25);
    }

    .logo-mark {
      width: 42px;
      height: 42px;
      display: grid;
      place-items: center;
      border-radius: 50%;
      background: linear-gradient(180deg, var(--bb-green-500), var(--bb-green-600));
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.45);
      color: var(--white);
      font-size: 24px;
      font-weight: 800;
      line-height: 1;
    }

    .logo-text {
      line-height: 1;
    }

    .logo-text strong {
      display: block;
      font-size: 1.2rem;
      letter-spacing: 0.03em;
    }

    .logo-text span {
      display: block;
      margin-top: 4px;
      font-size: 0.82rem;
      color: var(--muted);
    }

    .heading {
      display: grid;
      gap: 10px;
      margin-bottom: 22px;
    }

    .eyebrow {
      font-size: 0.84rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--bb-green-700);
    }

    h1 {
      margin: 0;
      font-size: clamp(2rem, 4vw, 3.3rem);
      line-height: 0.98;
      letter-spacing: -0.04em;
      max-width: 13ch;
    }

    .subtitle {
      margin: 0;
      max-width: 58ch;
      color: var(--muted);
      font-size: 1rem;
      line-height: 1.6;
    }

    .form-wrap {
      padding: 8px 30px 30px;
    }

    form {
      display: grid;
      gap: 18px;
    }

    .field-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
    }

    .field {
      display: grid;
      gap: 10px;
    }

    .field label {
      font-weight: 700;
      font-size: 0.96rem;
      letter-spacing: -0.02em;
    }

    .input-shell {
      display: flex;
      align-items: center;
      min-height: 76px;
      padding: 0 18px;
      background: linear-gradient(180deg, #ffffff 0%, #f7fcec 100%);
      border: 1px solid rgba(136, 188, 83, 0.34);
      border-radius: var(--radius-lg);
      transition: 0.22s ease;
    }

    .input-shell:focus-within,
    .social-box:focus-within {
      transform: translateY(-1px);
      border-color: var(--bb-green-500);
      box-shadow: 0 0 0 5px rgba(136, 188, 83, 0.14);
    }

    input[type="text"],
    input[type="tel"] {
      width: 100%;
      border: 0;
      outline: 0;
      background: transparent;
      font: inherit;
      color: var(--ink);
      font-size: 1.04rem;
      font-weight: 600;
    }

    input::placeholder {
      color: #8ca17f;
      font-weight: 500;
    }

    .social-box {
      padding: 16px 18px;
      min-height: 76px;
      background: linear-gradient(180deg, #ffffff 0%, #f7fcec 100%);
      border: 1px solid rgba(136, 188, 83, 0.34);
      border-radius: var(--radius-lg);
      transition: 0.22s ease;
    }

    .social-options {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
    }

    .social-option {
      position: relative;
    }

    .social-option input {
      position: absolute;
      inset: 0;
      opacity: 0;
      pointer-events: none;
    }

    .social-pill {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 12px 16px;
      border-radius: 999px;
      border: 1px solid rgba(136, 188, 83, 0.24);
      background: #fbfff7;
      cursor: pointer;
      transition: 0.2s ease;
      user-select: none;
      font-weight: 700;
      color: var(--ink);
    }

    .social-pill::before {
      font-size: 18px;
      line-height: 1;
    }

    .social-pill.telegram::before {
      content: "✈";
    }

    .social-pill.whatsapp::before {
      content: "◔";
    }

    .social-pill.vk::before {
      content: "VK";
      font-size: 12px;
      font-weight: 800;
    }

    .social-pill.email::before {
      content: "@";
      font-weight: 800;
    }

    .social-option input:checked + .social-pill {
      background: linear-gradient(180deg, var(--bb-green-500), var(--bb-green-600));
      color: var(--white);
      border-color: transparent;
      transform: translateY(-1px);
      box-shadow: 0 10px 22px rgba(105, 157, 60, 0.24);
    }

    .actions {
      display: flex;
      flex-direction: column;
      gap: 12px;
      align-items: center;
      margin-top: 8px;
    }

    .button {
      width: 100%;
      min-height: 72px;
      border: 0;
      border-radius: 999px;
      padding: 18px 28px;
      font: inherit;
      font-size: 1rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      color: var(--white);
      background: linear-gradient(180deg, var(--bb-green-600), var(--bb-green-700));
      cursor: pointer;
      box-shadow: 0 18px 30px rgba(80, 123, 45, 0.24);
      transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
    }

    .button:hover {
      transform: translateY(-2px);
      box-shadow: 0 24px 34px rgba(80, 123, 45, 0.26);
    }

    .button:disabled {
      opacity: 0.7;
      cursor: wait;
      transform: none;
    }

    .status {
      min-height: 24px;
      margin: 0;
      text-align: center;
      font-size: 0.95rem;
      color: var(--muted);
    }

    @media (max-width: 820px) {
      .field-grid {
        grid-template-columns: 1fr;
      }

      .hero,
      .form-wrap {
        padding-left: 18px;
        padding-right: 18px;
      }

      .social-pill {
        width: 100%;
        justify-content: center;
      }

      .social-options {
        display: grid;
        grid-template-columns: 1fr 1fr;
      }
    }

    @media (max-width: 520px) {
      .page {
        padding: 16px;
      }

      .card {
        border-radius: 22px;
      }

      .hero {
        padding-top: 20px;
      }

      .logo-row {
        width: 100%;
        justify-content: center;
      }

      .social-options {
        grid-template-columns: 1fr;
      }

      .button {
        min-height: 66px;
      }
    }
  </style>
</head>
<body>
  <main class="page">
    <section class="card">
      <div class="hero">
        <div class="logo-row" aria-label="B. Braun">
          <div class="logo-mark" aria-hidden="true">+</div>
          <div class="logo-text">
            <strong>B. Braun</strong>
            <span>Форма связи с представителями</span>
          </div>
        </div>

        <div class="heading">
          <div class="eyebrow">Контактная форма</div>
          <h1>Оставьте заявку для обратной связи</h1>
          <p class="subtitle">
            Заполните данные, чтобы представители B. Braun могли с вами связаться.
          </p>
        </div>
      </div>

      <div class="form-wrap">
        <form id="leadForm">
          <div class="field-grid">
            <div class="field">
              <label for="fullName">ФИО</label>
              <div class="input-shell">
                <input
                  id="fullName"
                  name="fullName"
                  type="text"
                  autocomplete="name"
                  placeholder="Например: Иванов Иван Иванович"
                />
              </div>
            </div>

            <div class="field">
              <label for="clinic">Название вашего ЛПУ или Мед. учреждения</label>
              <div class="input-shell">
                <input
                  id="clinic"
                  name="clinic"
                  type="text"
                  autocomplete="organization"
                  placeholder="Например: ГБУЗ ГКБ №..."
                />
              </div>
            </div>

            <div class="field">
              <label for="phone">Номер телефона</label>
              <div class="input-shell">
                <input
                  id="phone"
                  name="phone"
                  type="tel"
                  autocomplete="tel"
                  placeholder="+7 (___) ___-__-__"
                />
              </div>
            </div>

            <div class="field">
              <label>Соц. сеть для связи</label>
              <div class="social-box">
                <div class="social-options">
                  <label class="social-option">
                    <input type="radio" name="social" value="Telegram" />
                    <span class="social-pill telegram">Telegram</span>
                  </label>

                  <label class="social-option">
                    <input type="radio" name="social" value="WhatsApp" />
                    <span class="social-pill whatsapp">WhatsApp</span>
                  </label>

                  <label class="social-option">
                    <input type="radio" name="social" value="VK" />
                    <span class="social-pill vk">VK</span>
                  </label>

                  <label class="social-option">
                    <input type="radio" name="social" value="Email" />
                    <span class="social-pill email">Email</span>
                  </label>
                </div>
              </div>
            </div>
          </div>

          <div class="actions">
            <button class="button" id="submitBtn" type="submit">
              Проинформировать представителей B.Braun
            </button>
            <p class="status" id="status">Форма готова к отправке.</p>
          </div>
        </form>
      </div>
    </section>
  </main>

  <script>
    const EMAILJS_PUBLIC_KEY = "-7vwTG2tHewgjgn3x";
    const EMAILJS_SERVICE_ID = "service_enxggkv";
    const EMAILJS_TEMPLATE_ID = "template_qhjhiqx";
    const RECEIVER_EMAIL = "dan47447@gmail.com";

    const form = document.getElementById("leadForm");
    const statusEl = document.getElementById("status");
    const submitBtn = document.getElementById("submitBtn");

    emailjs.init({
      publicKey: EMAILJS_PUBLIC_KEY
    });

    function getFormData() {
      const formData = new FormData(form);
      return {
        fullName: (formData.get("fullName") || "").toString().trim(),
        clinic: (formData.get("clinic") || "").toString().trim(),
        phone: (formData.get("phone") || "").toString().trim(),
        social: (formData.get("social") || "").toString().trim()
      };
    }

    function hasAnyValue(data) {
      return Boolean(data.fullName || data.clinic || data.phone || data.social);
    }

    async function sendLead() {
      const data = getFormData();

      if (!hasAnyValue(data)) {
        statusEl.textContent = "Заполните хотя бы одно поле.";
        return;
      }

      submitBtn.disabled = true;
      statusEl.textContent = "Отправка данных...";

      try {
        await emailjs.send(EMAILJS_SERVICE_ID, EMAILJS_TEMPLATE_ID, {
          receiver_email: RECEIVER_EMAIL,
          full_name: data.fullName || "Не указано",
          clinic: data.clinic || "Не указано",
          phone: data.phone || "Не указано",
          social: data.social || "Не указано",
          page_url: window.location.href,
          sent_at: new Date().toLocaleString("ru-RU")
        });

        statusEl.textContent = "Заявка успешно отправлена.";
        form.reset();
      } catch (error) {
        console.error(error);
        statusEl.textContent = "Не удалось отправить данные. Проверьте настройки EmailJS.";
      } finally {
        submitBtn.disabled = false;
      }
    }

    form.addEventListener("submit", async function (event) {
      event.preventDefault();
      await sendLead();
    });
  </script>
</body>
</html>
